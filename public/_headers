/*
  X-Frame-Options: ALLOWALL
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Cache-Control: public, max-age=0, must-revalidate
  Content-Security-Policy: script-src 'self' data: 'sha256-saW1wFw9k+ji/e/imx/zV6bxl71vISF0yrEoD60cUGo=' 'sha256-w36slEqa9euNKxfvkw+LLGsDIr++3rsZXpZxtmRh8Aw=' 'sha256-+5XkZFazzJo8n0iOP4ti/cLCMUudTf//Mzkb7xNPXIc=' 'sha256-nRcgRt3XNN0aZXdzMDUhXYSzvNDbxXeNTBXS8ajcR38=' https://*.simplesocket.net https://*.exotek.co https://*.googleapis.com https://*.cloudflare.com; frame-src * blob:

/join
  ! Content-Security-Policy
  Content-Security-Policy: script-src 'self' 'sha256-viSWilXB5sYlQ+Ga8T8LdsqOzYVlVgZkRO7wmjuwVko=' https://*.simplesocket.net https://*.exotek.co https://*.googleapis.com https://*.cloudflare.com; frame-src * blob:

/export
  ! Content-Security-Policy
  Content-Security-Policy: script-src 'self' 'sha256-X6mmDHcwJEHs0FGxvR3d1QFcl1gwxvsBwsAZleep9LU=' https://*.simplesocket.net https://*.exotek.co https://*.googleapis.com https://*.cloudflare.com; frame-src * blob:

/embed
  ! Content-Security-Policy
  ! X-Frame-Options
  ! X-Content-Type-Options
  ! Referrer-Policy

/*.eot
  Cache-Control: max-age=1800
/*.otf
  Cache-Control: max-age=1800
/*.ttf
  Cache-Control: max-age=1800
/*.woff
  Cache-Control: max-age=1800

# Vite hashed assets - Cached for 3 months
/assets/*
  ! Cache-Control
  Cache-Control: public, max-age=7776000, immutable

# Prevent the Service Worker from being cached so it can instantly spot updates
/sw.js
  ! Cache-Control
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0

# Prevent index.html from being cached so it always points to the newest hashed JS files
/index.html
  ! Cache-Control
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Pragma: no-cache
  Expires: 0